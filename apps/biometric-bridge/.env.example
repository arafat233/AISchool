# School / tenant
SCHOOL_ID=school_abc123

# ZKTeco devices — comma-separated "name:host:port"
DEVICES=MainGate:192.168.1.201:4370,StaffEntrance:192.168.1.202:4370

# Poll interval (seconds)
POLL_INTERVAL_SECONDS=60

# Fetch window on first poll (minutes back)
FETCH_WINDOW_MINUTES=10

# Local Mosquitto broker (school LAN)
LOCAL_MQTT_URL=mqtt://mosquitto:1883
LOCAL_MQTT_USERNAME=
LOCAL_MQTT_PASSWORD=

# Cloud MQTT broker (same or remote — biometric-bridge subscribes here too)
CLOUD_MQTT_URL=mqtt://mosquitto:1883
CLOUD_MQTT_USERNAME=
CLOUD_MQTT_PASSWORD=

# Attendance microservice
ATTENDANCE_SERVICE_URL=http://attendance-service:3005
ATTENDANCE_SERVICE_API_KEY=

# Notification microservice
NOTIFICATION_SERVICE_URL=http://notification-service:3007

# Device health alert threshold (minutes)
HEALTH_ALERT_THRESHOLD_MINUTES=30

LOG_LEVEL=info
