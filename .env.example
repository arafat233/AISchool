# ─── Node ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=school_erp
POSTGRES_USER=school_erp
POSTGRES_PASSWORD=secret_change_in_production
DATABASE_URL=postgresql://school_erp:secret_change_in_production@localhost:5432/school_erp?schema=public

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=school-erp
KAFKA_GROUP_ID=school-erp-group

# ─── Auth Service ───────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
TOTP_ISSUER=SchoolERP

# ─── Google OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── Microsoft OAuth ────────────────────────────────────────────────────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_CALLBACK_URL=http://localhost:3001/auth/microsoft/callback

# ─── User Service ───────────────────────────────────────────────────────────
USER_SERVICE_PORT=3002

# ─── Student Service ────────────────────────────────────────────────────────
STUDENT_SERVICE_PORT=3003

# ─── Academic Service ───────────────────────────────────────────────────────
ACADEMIC_SERVICE_PORT=3004

# ─── Attendance Service ─────────────────────────────────────────────────────
ATTENDANCE_SERVICE_PORT=3005

# ─── Fee Service ────────────────────────────────────────────────────────────
FEE_SERVICE_PORT=3006
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Notification Service ───────────────────────────────────────────────────
NOTIFICATION_SERVICE_PORT=3007
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SCHOOL
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@schoolerp.com
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=
WATI_API_KEY=
WATI_BASE_URL=

# ─── Exam Service ───────────────────────────────────────────────────────────
EXAM_SERVICE_PORT=3008

# ─── HR Service ─────────────────────────────────────────────────────────────
HR_SERVICE_PORT=3009

# ─── Payroll Service ────────────────────────────────────────────────────────
PAYROLL_SERVICE_PORT=3010

# ─── Transport Service ──────────────────────────────────────────────────────
TRANSPORT_SERVICE_PORT=3011
MQTT_BROKER_URL=mqtt://localhost:1883
GOOGLE_MAPS_API_KEY=

# ─── Storage (S3 / R2) ──────────────────────────────────────────────────────
STORAGE_PROVIDER=s3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=school-erp-files
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=school-erp-files

# ─── Elasticsearch ──────────────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ─── SaaS / API Gateway ─────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
FRONTEND_URL=http://localhost:3100

# ─── Portals ────────────────────────────────────────────────────────────────
ADMIN_PORTAL_PORT=3100
TEACHER_PORTAL_PORT=3101
STUDENT_PORTAL_PORT=3102
PARENT_PORTAL_PORT=3103
COMPANY_PORTAL_PORT=3104

# ─── Puppeteer / PDF ────────────────────────────────────────────────────────
CHROMIUM_PATH=/usr/bin/chromium-browser

# ─── Blockchain ─────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/your-key
BLOCKCHAIN_PRIVATE_KEY=
CERTIFICATE_CONTRACT_ADDRESS=
