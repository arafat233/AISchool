  amountRs    Float
  description String
  referenceId String?       // orderId or payment gateway txn id
  createdAt   DateTime      @default(now())

  @@map("wallet_transactions")
}

model FssaiRecord {
  id               String   @id @default(cuid())
  schoolId         String
  licenseNo        String
  licenseExpiry    DateTime
  operatorName     String?
  lastInspectionAt DateTime?
  waterTestDate    DateTime?
  waterTestResult  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  staffCertificates FssaiStaffCertificate[]
  safetyChecklists  FoodSafetyChecklist[]
  sampleLogs        FoodSampleLog[]

  @@unique([schoolId])
  @@map("fssai_records")
}

model FssaiStaffCertificate {
  id          String      @id @default(cuid())
  fssaiId     String
  fssai       FssaiRecord @relation(fields: [fssaiId], references: [id])
  staffName   String
  certNo      String?
  issuedOn    DateTime?
  expiresOn   DateTime?
  createdAt   DateTime    @default(now())

  @@map("fssai_staff_certificates")
}

model FoodSafetyChecklist {
  id          String      @id @default(cuid())
  fssaiId     String
  fssai       FssaiRecord @relation(fields: [fssaiId], references: [id])
  month       String      // "2026-04"
  items       Json        // [{check, passed, notes}]
  completedBy String
  completedAt DateTime    @default(now())

  @@unique([fssaiId, month])
  @@map("food_safety_checklists")
}

model FoodSampleLog {
  id          String      @id @default(cuid())
  fssaiId     String
  fssai       FssaiRecord @relation(fields: [fssaiId], references: [id])
  sampleDate  DateTime
  mealType    String
  items       String[]
  retainedUntil DateTime
  notes       String?
  createdAt   DateTime    @default(now())

  @@map("food_sample_logs")
}
