// ─────────────────────────────────────────────────────────────────────────────
// School ERP — Complete Prisma Schema
// All 60+ tables across all modules
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum TenantType {
  TRUST
  COMPANY
  INDIVIDUAL
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CHURNED
}

enum SubscriptionPlan {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  VICE_PRINCIPAL
  HOD
  ACCOUNTANT
  CLASS_TEACHER
  SUBJECT_TEACHER
  LIBRARIAN
  TRANSPORT_MANAGER
  NURSE
  GATE_SECURITY
  CANTEEN_MANAGER
  COUNSELLOR
  NCC_OFFICER
  NSS_OFFICER
  STUDENT
  PARENT
  ALUMNI
  EXTERNAL_EXAMINER
  AUDITOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum EnquiryStatus {
  NEW
  CONTACTED
  VISITED
  INTERESTED
  APPLICATION_SUBMITTED
  CONVERTED
  NOT_INTERESTED
  LOST
}

enum EnquirySource {
  WALK_IN
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  ADVERTISEMENT
  PHONE
  OTHER
}

enum AdmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAITLISTED
  ENROLLED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  GRADUATED
  EXPELLED
}

enum ParentRelation {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum StaffStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  TERMINATED
  RETIRED
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  MATERNITY
  PATERNITY
  SPECIAL
  LOSS_OF_PAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FeeInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  WAIVED
  CANCELLED
}

enum PaymentMode {
  CASH
  CHEQUE
  DEMAND_DRAFT
  ONLINE_RAZORPAY
  ONLINE_UPI
  BANK_TRANSFER
  NACH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ExamType {
  UNIT_TEST
  MID_TERM
  FINAL
  BOARD
  ONLINE_DIAGNOSTIC
  PRACTICAL
  VIVA
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  MARKS_ENTRY
  RESULT_CALCULATED
  PUBLISHED
  CANCELLED
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookStatus {
  AVAILABLE
  ISSUED
  RESERVED
  LOST
  DAMAGED
  UNDER_MAINTENANCE
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ORDERED
  RECEIVED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  PROCESSED
  APPROVED
  DISBURSED
}

enum CertificateType {
  BONAFIDE
  CHARACTER
  MIGRATION
  TRANSFER
  SPORTS_ACHIEVEMENT
  ATTENDANCE
  PARTICIPATION
  COMMUNITY_SERVICE
  CUSTOM
}

enum SubjectType {
  COMPULSORY
  ELECTIVE
  VOCATIONAL
  CO_CURRICULAR
}

enum ConcessionType {
  FLAT
  PERCENTAGE
}

enum HealthIncidentSeverity {
  MINOR
  MODERATE
  SEVERE
  CRITICAL
}

// ═══════════════════════════════════════════════════════════════════════════
// SAAS — TENANCY & AUTH
// ═══════════════════════════════════════════════════════════════════════════

model Tenant {
  id               String           @id @default(cuid())
  name             String
  type             TenantType       @default(COMPANY)
  plan             SubscriptionPlan @default(BASIC)
  status           TenantStatus     @default(TRIAL)
  trialEndsAt      DateTime?
  subscriptionEndsAt DateTime?
  maxStudents      Int              @default(500)
  billingEmail     String?
  gstin            String?
  logoUrl          String?
  settings         Json             @default("{}")
  featureFlags     Json             @default("{}")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  schools  School[]
  users    User[]
  invoices TenantInvoice[]

  @@map("tenants")
}

model TenantInvoice {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("INR")
  studentCount Int
  period       String   // e.g. "2024-04"
  dueDate      DateTime
  paidAt       DateTime?
  paymentMode  PaymentMode?
  txnId        String?
  status       PaymentStatus @default(PENDING)
  pdfUrl       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("tenant_invoices")
}

model User {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  email        String?
  phone        String?
  passwordHash String?
  role         UserRole
  status       UserStatus @default(PENDING_VERIFICATION)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  profile            UserProfile?
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  staff              Staff?
  student            Student?
  parentStudents     StudentParent[]
  twoFactorAuth      TwoFactorAuth?
  lessonDiscussions  LessonDiscussion[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId, role])
  @@map("users")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  dob         DateTime?
  gender      Gender?
  photoUrl    String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  languagePref String  @default("en")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_profiles")
}

model TwoFactorAuth {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret    String   // encrypted TOTP secret
  isEnabled Boolean  @default(false)
  backupCodes String[] // hashed backup codes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("two_factor_auth")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  schoolId    String?
  action      String   // e.g. "student.created", "fee.payment.recorded"
  entityType  String?
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([schoolId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════════
// SCHOOL & ACADEMIC CORE
// ═══════════════════════════════════════════════════════════════════════════

model School {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  name           String
  code           String   // short school code e.g. "DPS-NE"
  address        String?
  city           String?
  state          String?
  pincode        String?
  phone          String?
  email          String?
  website        String?
  logoUrl        String?
  affiliationNo  String?  // board affiliation number
  udiseCode      String?  // government UDISE code
  boardType      String?  // CBSE, ICSE, STATE, IB, CAMBRIDGE
  timezone       String   @default("Asia/Kolkata")
  currency       String   @default("INR")
  settings       Json     @default("{}")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYears      AcademicYear[]
  gradeLevels        GradeLevel[]
  subjects           Subject[]
  departments        Department[]
  staff              Staff[]
  students           Student[]
  feeHeads           FeeHead[]
  exams              Exam[]
  routes             Route[]
  vehicles           Vehicle[]
  events             Event[]
  surveys            Survey[]
  scholarshipSchemes ScholarshipScheme[]
  complianceItems    ComplianceCalendarItem[]
  notificationTemplates NotificationTemplate[]

  @@unique([tenantId, code])
  @@map("schools")
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String   // e.g. "2024-25"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  terms          Term[]
  feeStructures  FeeStructure[]
  exams          Exam[]
  payrollRuns    PayrollRun[]
  promotions     ClassPromotion[]
  studentTransports StudentTransport[]

  @@unique([schoolId, name])
  @@map("academic_years")
}

model Term {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String       // e.g. "Term 1", "First Half"
  startDate      DateTime
  endDate        DateTime
  sequence       Int
  createdAt      DateTime     @default(now())

  feeStructures FeeStructure[]
  exams         Exam[]

  @@unique([academicYearId, sequence])
  @@map("terms")
}

model GradeLevel {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String   // "Grade 1", "Class X", "Nursery"
  numericLevel Int?  // 1-12 for sorting
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sections        Section[]
  classSubjects   ClassSubject[]
  feeStructures   FeeStructure[]
  timetableSlots  TimetableSlot[]
  courses         Course[]
  syllabicTopics  SyllabicTopic[]
  homework        Homework[]

  @@unique([schoolId, name])
  @@map("grade_levels")
}

model Section {
  id           String     @id @default(cuid())
  gradeLevelId String
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id])
  name         String     // "A", "B", "C"
  maxStrength  Int        @default(40)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  students          Student[]
  attendanceSessions AttendanceSession[]
  timetableSlots    TimetableSlot[]
  classTeachers     ClassTeacher[]
  liveClasses       LiveClass[]
  homework          Homework[]   @relation("HomeworkSection")

  @@unique([gradeLevelId, name])
  @@map("sections")
}

model Subject {
  id        String      @id @default(cuid())
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id])
  name      String
  code      String
  type      SubjectType @default(COMPULSORY)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  classSubjects    ClassSubject[]
  teacherSubjects  TeacherSubject[]
  timetableSlots   TimetableSlot[]
  examSchedules    ExamSchedule[]
  courses          Course[]
  syllabicTopics   SyllabicTopic[]
  homework         Homework[]

  @@unique([schoolId, code])
  @@map("subjects")
}

model ClassSubject {
  id           String     @id @default(cuid())
  gradeLevelId String
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id])
  subjectId    String
  subject      Subject    @relation(fields: [subjectId], references: [id])
  isElective   Boolean    @default(false)
  periodsPerWeek Int      @default(5)

  @@unique([gradeLevelId, subjectId])
  @@map("class_subjects")
}

model TimetableSlot {
  id           String     @id @default(cuid())
  gradeLevelId String
  gradeLevel   GradeLevel @relation(fields: [gradeLevelId], references: [id])
  sectionId    String
  section      Section    @relation(fields: [sectionId], references: [id])
  subjectId    String
  subject      Subject    @relation(fields: [subjectId], references: [id])
  staffId      String
  staff        Staff      @relation(fields: [staffId], references: [id])
  dayOfWeek    Int        // 1=Monday .. 6=Saturday
  periodNumber Int
  startTime    String     // "09:00"
  endTime      String     // "09:45"
  roomNo       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("timetable_slots")
}

model ClassTeacher {
  id             String       @id @default(cuid())
  sectionId      String
  section        Section      @relation(fields: [sectionId], references: [id])
  staffId        String
  staff          Staff        @relation(fields: [staffId], references: [id])
  academicYearId String
  isActive       Boolean      @default(true)
  assignedAt     DateTime     @default(now())

  @@unique([sectionId, academicYearId])
  @@map("class_teachers")
}

// ═══════════════════════════════════════════════════════════════════════════
// ADMISSION
// ═══════════════════════════════════════════════════════════════════════════

model Enquiry {
  id             String        @id @default(cuid())
  schoolId       String
  childName      String
  childDob       DateTime?
  applyingForGrade String?
  parentName     String
  parentPhone    String
  parentEmail    String?
  source         EnquirySource @default(WALK_IN)
  referredBy     String?
  status         EnquiryStatus @default(NEW)
  notes          String?
  assignedTo     String?       // staff user id
  nextFollowUpAt DateTime?
  convertedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  followUps    EnquiryFollowUp[]
  applications AdmissionApplication[]

  @@index([schoolId])
  @@index([status])
  @@map("enquiries")
}

model EnquiryFollowUp {
  id        String   @id @default(cuid())
  enquiryId String
  enquiry   Enquiry  @relation(fields: [enquiryId], references: [id])
  staffId   String?
  notes     String
  outcome   String?  // "Called - will visit", "Visited - interested"
  nextAction String?
  followUpAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@map("enquiry_follow_ups")
}

model AdmissionApplication {
  id             String          @id @default(cuid())
  schoolId       String
  enquiryId      String?
  enquiry        Enquiry?        @relation(fields: [enquiryId], references: [id])
  applicationNo  String          @unique
  childFirstName String
  childLastName  String
  childDob       DateTime
  gender         Gender
  nationality    String          @default("Indian")
  religion       String?
  bloodGroup     String?
  applyingForGradeId String?
  academicYearId String?
  previousSchool String?
  previousClass  String?
  fatherName     String?
  fatherPhone    String?
  fatherEmail    String?
  fatherOccupation String?
  motherName     String?
  motherPhone    String?
  motherEmail    String?
  motherOccupation String?
  address        String?
  status         AdmissionStatus @default(DRAFT)
  reviewedBy     String?         // staff id
  reviewedAt     DateTime?
  rejectionReason String?
  approvedAt     DateTime?
  enrolledStudentId String?      // once approved
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  documents ApplicationDocument[]

  @@index([schoolId, status])
  @@map("admission_applications")
}

model ApplicationDocument {
  id            String               @id @default(cuid())
  applicationId String
  application   AdmissionApplication @relation(fields: [applicationId], references: [id])
  documentType  String               // "birth_certificate", "aadhar", "photo", "previous_marksheet"
  fileUrl       String
  isVerified    Boolean              @default(false)
  uploadedAt    DateTime             @default(now())

  @@map("application_documents")
}

// ═══════════════════════════════════════════════════════════════════════════
// STUDENTS
// ═══════════════════════════════════════════════════════════════════════════

model Student {
  id             String        @id @default(cuid())
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id])
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id])
  admissionNo    String
  gradeLevelId   String?
  sectionId      String?
  section        Section?      @relation(fields: [sectionId], references: [id])
  rollNo         String?
  admissionDate  DateTime      @default(now())
  academicYearId String?
  status         StudentStatus @default(ACTIVE)
  houseColor     String?       // for house system
  isCwsn         Boolean       @default(false)  // differently-abled
  apaarId        String?       // APAAR/ABC national ID
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  parents             StudentParent[]
  documents           StudentDocument[]
  attendanceRecords   AttendanceRecord[]
  feeInvoices         FeeInvoice[]
  hallTickets         HallTicket[]
  results             Result[]
  marksEntries        MarksEntry[]
  transportAssignment StudentTransport?
  medicalProfile      StudentMedicalProfile?
  promotions          ClassPromotion[]
  transferCertificates TransferCertificate[]
  certificates        IssuedCertificate[]
  scholarshipApps     ScholarshipApplication[]
  iepProfile          IepProfile?
  readingLogs         ReadingLog[]
  portfolioItems      PortfolioItem[]
  lessonProgress      LessonProgress[]
  liveClassAttendance LiveClassAttendance[]
  homeworkAcknowledgements HomeworkAcknowledgement[]
  certificateRequests CertificateRequest[] @relation("CertificateRequests")
  ptmBookings         PtmBooking[]
  routeAssignment     StudentRouteAssignment?
  medicalProfile      StudentMedicalProfile?
  nurseVisits         NurseVisitLog[]
  medicationLogs      MedicationAdminLog[]
  healthIncidents     HealthIncident[]
  vaccinations        VaccinationRecord[]
  fitnessRecords      StudentFitnessRecord[]
  counsellingSessions CounsellingSession[]
  disciplineIncidents DisciplineIncident[]
  cafeteriaOrders     CafeteriaOrder[]
  wallet              StudentWallet?

  @@unique([schoolId, admissionNo])
  @@index([schoolId, gradeLevelId, sectionId])
  @@index([status])
  @@map("students")
}

model StudentParent {
  id        String         @id @default(cuid())
  studentId String
  student   Student        @relation(fields: [studentId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  relation  ParentRelation @default(FATHER)
  isPrimary Boolean        @default(false)
  createdAt DateTime       @default(now())

  @@unique([studentId, userId])
  @@map("student_parents")
}

model StudentDocument {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  documentType String
  fileUrl      String
  isVerified   Boolean  @default(false)
  uploadedAt   DateTime @default(now())

  @@map("student_documents")
}

model ClassPromotion {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  fromGradeId    String?
  toGradeId      String?
  fromSectionId  String?
  toSectionId    String?
  isPromoted     Boolean      @default(true)
  remarks        String?
  promotedBy     String?      // staff id
  promotedAt     DateTime     @default(now())

  @@map("class_promotions")
}

model TransferCertificate {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  tcNo          String   @unique
  issueDate     DateTime @default(now())
  reasonForTC   String?
  lastDayOfAttendance DateTime?
  duesClearedAt DateTime?
  pdfUrl        String?
  issuedBy      String?  // staff id

  @@map("transfer_certificates")
}

model IepProfile {
  id          String   @id @default(cuid())
  studentId   String   @unique
  student     Student  @relation(fields: [studentId], references: [id])
  condition   String?
  specialEducatorId String?
  accommodations Json   @default("[]")  // array of accommodation strings
  goals       Json     @default("[]")
  extraTimePercent Int @default(0)      // e.g. 25 = 25% extra time in exams
  separateRoom Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("iep_profiles")
}

// ═══════════════════════════════════════════════════════════════════════════
// STAFF & HR
// ═══════════════════════════════════════════════════════════════════════════

model Department {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  name      String
  headId    String?  // HOD staff id
  createdAt DateTime @default(now())

  designations Designation[]
  staff        Staff[]
  vacancies    JobVacancy[]

  @@unique([schoolId, name])
  @@map("departments")
}

model Designation {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  name         String     // "Principal", "Senior Teacher", "PRT"
  salaryGrade  String?
  createdAt    DateTime   @default(now())

  staff              Staff[]
  salaryComponents   SalaryStructureComponent[]
  vacancies          JobVacancy[]

  @@map("designations")
}

model Staff {
  id              String      @id @default(cuid())
  schoolId        String
  school          School      @relation(fields: [schoolId], references: [id])
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id])
  employeeCode    String
  designationId   String?
  designation     Designation? @relation(fields: [designationId], references: [id])
  departmentId    String?
  department      Department?  @relation(fields: [departmentId], references: [id])
  joinDate        DateTime
  confirmationDate DateTime?
  bankAccountNo   String?
  bankIfsc        String?
  bankName        String?
  pfAccountNo     String?
  esiNo           String?
  panNo           String?
  aadharNo        String?
  emergencyContact String?
  bloodGroup      String?
  qualifications  Json        @default("[]")
  status          StaffStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  teacherSubjects     TeacherSubject[]
  classTeachers       ClassTeacher[]
  timetableSlots      TimetableSlot[]
  leaveBalances       LeaveBalance[]
  leaveApplications   LeaveApplication[]
  payslips            Payslip[]
  staffAttendance     StaffAttendance[]
  appraisals          StaffAppraisal[]
  syllabusProgress    SyllabusProgress[]
  documents           StaffDocument[]
  trainingAttendances TrainingAttendance[]
  trainingFeedbacks   TrainingFeedback[]
  exits               StaffExit[]
  grievances          StaffGrievance[]
  freeSlots           FreeSlot[]
  salaryAdvances      SalaryAdvance[]
  gratuityProvisions  GratuityProvision[]
  ptmSlots            PtmSlot[]

  @@unique([schoolId, employeeCode])
  @@map("staff")
}

model TeacherSubject {
  id             String     @id @default(cuid())
  staffId        String
