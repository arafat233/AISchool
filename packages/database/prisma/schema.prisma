  description  String?
  cost         Float?
  serviceDate  DateTime
  nextDueDate  DateTime?
  odometer     Int?
  vendorName   String?
  createdAt    DateTime @default(now())

  @@index([vehicleId])
  @@map("vehicle_maintenance_logs")
}

