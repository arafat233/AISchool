  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([staffId, date])
  @@map("staff_attendance")
}

// ═══════════════════════════════════════════════════════════════════════════
// FEE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

model FeeHead {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  name        String   // "Tuition", "Transport", "Library", "Sports"
  description String?
  isActive    Boolean  @default(true)
  isTaxable   Boolean  @default(false)
  hsnSacCode  String?
  taxRate     Decimal  @db.Decimal(5, 2) @default(0)
  createdAt   DateTime @default(now())

  feeStructures    FeeStructure[]
  feeInvoiceItems  FeeInvoiceItem[]
  concessions      Concession[]

  @@unique([schoolId, name])
  @@map("fee_heads")
}

model FeeStructure {
  id             String       @id @default(cuid())
  schoolId       String
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  termId         String?
  term           Term?        @relation(fields: [termId], references: [id])
  gradeLevelId   String
  gradeLevel     GradeLevel   @relation(fields: [gradeLevelId], references: [id])
  feeHeadId      String
  feeHead        FeeHead      @relation(fields: [feeHeadId], references: [id])
  amount         Decimal      @db.Decimal(12, 2)
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([academicYearId, termId, gradeLevelId, feeHeadId])
  @@map("fee_structures")
}

model FeeInvoice {
  id             String           @id @default(cuid())
  schoolId       String
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id])
  academicYearId String
  invoiceNo      String           @unique
  term           String?
  totalAmount    Decimal          @db.Decimal(12, 2)
  discountAmount Decimal          @db.Decimal(12, 2) @default(0)
  taxAmount      Decimal          @db.Decimal(12, 2) @default(0)
  netAmount      Decimal          @db.Decimal(12, 2)
  paidAmount     Decimal          @db.Decimal(12, 2) @default(0)
  dueDate        DateTime
  status         FeeInvoiceStatus @default(ISSUED)
  lateFeeApplied Decimal          @db.Decimal(10, 2) @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  items    FeeInvoiceItem[]
  payments FeePayment[]

  @@index([studentId])
  @@index([schoolId, status])
  @@map("fee_invoices")
}

model FeeInvoiceItem {
  id          String     @id @default(cuid())
  invoiceId   String
  invoice     FeeInvoice @relation(fields: [invoiceId], references: [id])
  feeHeadId   String
  feeHead     FeeHead    @relation(fields: [feeHeadId], references: [id])
  amount      Decimal    @db.Decimal(12, 2)
  concessionAmt Decimal  @db.Decimal(12, 2) @default(0)
  taxAmt      Decimal    @db.Decimal(12, 2) @default(0)
  netAmount   Decimal    @db.Decimal(12, 2)

  @@map("fee_invoice_items")
}

model FeePayment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       FeeInvoice    @relation(fields: [invoiceId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @default(now())
  mode          PaymentMode   @default(CASH)
  txnId         String?       // gateway transaction id
  gatewayOrderId String?
  gatewayPaymentId String?
  gatewaySignature String?
  chequeNo      String?
  bankName      String?
  receiptNo     String        @unique
  receiptUrl    String?
  status        PaymentStatus @default(SUCCESS)
  recordedBy    String?       // staff id for cash payments
  createdAt     DateTime      @default(now())

  @@index([invoiceId])
  @@map("fee_payments")
}

model Concession {
  id           String         @id @default(cuid())
  schoolId     String
  studentId    String
  feeHeadId    String
  feeHead      FeeHead        @relation(fields: [feeHeadId], references: [id])
  type         ConcessionType @default(PERCENTAGE)
  value        Decimal        @db.Decimal(10, 2) // % or flat amount
  reason       String
  academicYearId String?
  approvedBy   String?
  approvedAt   DateTime?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())

  @@map("concessions")
}

model LateFeeRule {
  id              String   @id @default(cuid())
  schoolId        String
  feeHeadId       String?  // null = applies to all heads
  triggerAfterDays Int     // days after due date
  type            ConcessionType @default(FLAT)
  amount          Decimal  @db.Decimal(10, 2)
  maxAmount       Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  @@map("late_fee_rules")
}

model PostDatedCheque {
  id           String        @id @default(cuid())
  schoolId     String
  studentId    String
  invoiceId    String?
  chequeNo     String
  bankName     String
  bankBranch   String?
  amount       Decimal       @db.Decimal(12, 2)
  chequeDate   DateTime
  depositedAt  DateTime?
  clearedAt    DateTime?
  bouncedAt    DateTime?
  bounceReason String?
  status       String        @default("PENDING") // PENDING, DEPOSITED, CLEARED, BOUNCED, RETURNED
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("post_dated_cheques")
}

// ═══════════════════════════════════════════════════════════════════════════
// EXAM & RESULTS
// ═══════════════════════════════════════════════════════════════════════════

model Exam {
  id             String     @id @default(cuid())
  schoolId       String
  school         School     @relation(fields: [schoolId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  termId         String?
  term           Term?      @relation(fields: [termId], references: [id])
  name           String
  type           ExamType   @default(UNIT_TEST)
  status         ExamStatus @default(DRAFT)
  internalsWeight Decimal   @db.Decimal(5, 2) @default(0)  // % weight for internals
  finalsWeight   Decimal    @db.Decimal(5, 2) @default(100)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  schedules   ExamSchedule[]
  hallTickets HallTicket[]
  results     Result[]

  @@index([schoolId, academicYearId])
  @@map("exams")
}

model ExamSchedule {
  id           String    @id @default(cuid())
  examId       String
  exam         Exam      @relation(fields: [examId], references: [id])
  subjectId    String
  subject      Subject   @relation(fields: [subjectId], references: [id])
  gradeLevelId String
  examDate     DateTime
  startTime    String?
  durationMins Int       @default(180)
  maxMarks     Decimal   @db.Decimal(6, 2)
  passMarks    Decimal   @db.Decimal(6, 2)
  venue        String?
  createdAt    DateTime  @default(now())

  marksEntries MarksEntry[]

  @@unique([examId, subjectId, gradeLevelId])
  @@map("exam_schedules")
}

model HallTicket {
  id              String   @id @default(cuid())
  examId          String
  exam            Exam     @relation(fields: [examId], references: [id])
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  ticketNo        String   @unique
  seatNo          String?
  venueAllocation String?
  pdfUrl          String?
  generatedAt     DateTime @default(now())

  @@unique([examId, studentId])
  @@map("hall_tickets")
}

model MarksEntry {
  id             String       @id @default(cuid())
  scheduleId     String
  schedule       ExamSchedule @relation(fields: [scheduleId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  marksObtained  Decimal      @db.Decimal(6, 2)
  grade          String?
  isAbsent       Boolean      @default(false)
  isGraceMark    Boolean      @default(false)
  graceMark      Decimal      @db.Decimal(4, 2) @default(0)
  enteredById    String       // staff id
  enteredAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([scheduleId, studentId])
  @@map("marks_entries")
}

model Result {
  id             String  @id @default(cuid())
  examId         String
  exam           Exam    @relation(fields: [examId], references: [id])
  studentId      String
  student        Student @relation(fields: [studentId], references: [id])
  totalMarks     Decimal @db.Decimal(8, 2)
  maxMarks       Decimal @db.Decimal(8, 2)
  percentage     Decimal @db.Decimal(5, 2)
  grade          String?
  classRank      Int?
  sectionRank    Int?
  isPassed       Boolean @default(true)
  subjectResults Json    // [{subjectId, subject, marks, maxMarks, grade}]
  reportCardUrl  String?
  calculatedAt   DateTime @default(now())
  publishedAt    DateTime?

  @@unique([examId, studentId])
  @@index([studentId])
  @@map("results")
}

model QuestionBank {
  id           String   @id @default(cuid())
  schoolId     String
  subjectId    String
  gradeLevelId String?
  questionType String   // MCQ, TRUE_FALSE, SHORT_ANSWER, FILL_BLANK, LONG_ANSWER
  questionText String   @db.Text
  options      Json?    // for MCQ: [{label, text, isCorrect}]
  correctAnswer String?
  marks        Decimal  @db.Decimal(4, 2) @default(1)
  difficulty   String   @default("MEDIUM") // EASY, MEDIUM, HARD
  topic        String?
  tags         String[]
  createdBy    String   // staff id
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId, subjectId, gradeLevelId])
  @@map("question_bank")
}

model OnlineTest {
  id               String   @id @default(cuid())
  schoolId         String
  title            String
  subjectId        String?
  gradeLevelId     String?
  durationMins     Int      @default(60)
  passingPercent   Decimal  @db.Decimal(5, 2) @default(40)
  shuffleQuestions Boolean  @default(false)
  showResultAfter  Boolean  @default(true)
  startAt          DateTime?
  endAt            DateTime?
  maxAttempts      Int      @default(1)
  isPublished      Boolean  @default(false)
  questionIds      String[] // ordered list of QuestionBank ids
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempts OnlineTestAttempt[]

  @@map("online_tests")
}

model OnlineTestAttempt {
  id          String     @id @default(cuid())
  testId      String
  test        OnlineTest @relation(fields: [testId], references: [id])
  studentId   String
  startedAt   DateTime   @default(now())
  submittedAt DateTime?
  score       Decimal?   @db.Decimal(6, 2)
  maxScore    Decimal?   @db.Decimal(6, 2)
  percentage  Decimal?   @db.Decimal(5, 2)
  answers     Json       @default("{}") // {questionId: selectedAnswer}
  timeTaken   Int?       // seconds
  isAutoSubmit Boolean   @default(false)

  @@unique([testId, studentId])
  @@map("online_test_attempts")
}

// ═══════════════════════════════════════════════════════════════════════════
// TRANSPORT
// ═══════════════════════════════════════════════════════════════════════════

model Route {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  name       String
  startPoint String?
  endPoint   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  stops    Stop[]
  vehicles Vehicle[]
  trips    Trip[]

  @@map("routes")
}

model Stop {
  id           String   @id @default(cuid())
  routeId      String
  route        Route    @relation(fields: [routeId], references: [id])
  name         String
  latitude     Float
  longitude    Float
  sequence     Int
  expectedTime String?  // "07:30"
  isActive     Boolean  @default(true)

  studentAssignments StudentTransport[]

  @@unique([routeId, sequence])
  @@map("stops")
}

model Vehicle {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  registrationNo String  @unique
  type          String   @default("BUS") // BUS, VAN, AUTO
  capacity      Int
  make          String?
  model         String?
  yearOfMfg     Int?
  gpsDeviceId   String?  // for MQTT tracking
  routeId       String?
  route         Route?   @relation(fields: [routeId], references: [id])
  currentDriverId String?
  insuranceExpiry DateTime?
  pucExpiry     DateTime?
  fitnessExpiry DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driver  Driver?
  trips   Trip[]

  @@map("vehicles")
}

model Driver {
  id             String   @id @default(cuid())
  schoolId       String
  vehicleId      String?  @unique
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id])
  staffId        String?  // if driver is school staff
  name           String
  phone          String
  licenseNo      String   @unique
  licenseExpiry  DateTime
  licenseType    String   @default("LMV") // LMV, TRANSPORT
  bloodGroup     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("drivers")
}

model StudentTransport {
  id             String       @id @default(cuid())
  studentId      String       @unique
  student        Student      @relation(fields: [studentId], references: [id])
  routeId        String
  stopId         String
  stop           Stop         @relation(fields: [stopId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  pickupType     String       @default("BOTH") // PICKUP, DROP, BOTH
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@map("student_transport")
}

model Trip {
  id          String     @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle    @relation(fields: [vehicleId], references: [id])
  routeId     String
  route       Route      @relation(fields: [routeId], references: [id])
  driverId    String?
  tripDate    DateTime   @db.Date
  startedAt   DateTime?
  endedAt     DateTime?
  tripType    String     @default("MORNING") // MORNING, AFTERNOON, EVENING, TRIP
  status      TripStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime   @default(now())

  @@map("trips")
}

// ═══════════════════════════════════════════════════════════════════════════
// LIBRARY
// ═══════════════════════════════════════════════════════════════════════════

model BookCatalogue {
  id          String   @id @default(cuid())
  schoolId    String
  isbn        String?
  title       String
  author      String?
  publisher   String?
  edition     String?
  year        Int?
  category    String?
  language    String   @default("English")
  totalCopies Int      @default(1)
  availCopies Int      @default(1)
  shelfLocation String?
  coverUrl    String?
  isDigital   Boolean  @default(false)
  digitalUrl  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  issues BookIssue[]

  @@index([schoolId])
  @@map("book_catalogue")
}

model BookIssue {
  id           String        @id @default(cuid())
  bookId       String
  book         BookCatalogue @relation(fields: [bookId], references: [id])
  memberId     String        // user id (student or staff)
  memberType   String        @default("STUDENT")
  issueDate    DateTime      @default(now())
  dueDate      DateTime
  returnDate   DateTime?
  renewalCount Int           @default(0)
  status       BookStatus    @default(ISSUED)
  fine         Decimal       @db.Decimal(8, 2) @default(0)
  finePaid     Boolean       @default(false)
  issuedBy     String        // staff id
  returnedTo   String?       // staff id

  @@index([memberId])
  @@map("book_issues")
}

// ═══════════════════════════════════════════════════════════════════════════
// HEALTH & MEDICAL
// ═══════════════════════════════════════════════════════════════════════════

model StudentMedicalProfile {
  id              String   @id @default(cuid())
  studentId       String   @unique
  student         Student  @relation(fields: [studentId], references: [id])
  bloodGroup      String?
  allergies       String[]
  chronicConditions String[]
  currentMedications String[]
  doctorName      String?
  doctorPhone     String?
  insurancePolicy String?
  emergencyContact String?
  notes           String?
  updatedAt       DateTime @updatedAt

  @@map("student_medical_profiles")
}

model NurseVisitLog {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  visitDate   DateTime @default(now())
  complaint   String
  vitals      Json?    // {temperature, bp, pulse, weight, height}
  treatment   String?
  medication  String?
  sentHome    Boolean  @default(false)
  parentNotified Boolean @default(false)
  followUpNeeded Boolean @default(false)
  nurseId     String   // staff id
  createdAt   DateTime @default(now())

  @@index([studentId])
  @@map("nurse_visit_logs")
}

model MedicationSchedule {
  id             String   @id @default(cuid())
  studentId      String
  medicationName String
  dosage         String
  frequency      String   // "Once daily after lunch"
  scheduledTimes String[] // ["12:30"]
  startDate      DateTime
  endDate        DateTime?
  prescribedBy   String?
  parentConsent  Boolean  @default(false)
  consentDocUrl  String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  administrationLogs MedicationLog[]

  @@map("medication_schedules")
}

model MedicationLog {
  id           String             @id @default(cuid())
  scheduleId   String
  schedule     MedicationSchedule @relation(fields: [scheduleId], references: [id])
  administeredAt DateTime         @default(now())
  administeredBy String           // nurse staff id
  dosageGiven  String
  notes        String?
  missed       Boolean            @default(false)
  missedReason String?

  @@map("medication_logs")
}

model HealthIncident {
  id            String                 @id @default(cuid())
  schoolId      String
  studentId     String?
  staffId       String?
  incidentDate  DateTime               @default(now())
  description   String
  severity      HealthIncidentSeverity @default(MINOR)
  actionTaken   String?
  ambulanceCalled Boolean              @default(false)
  hospitalName  String?
  parentNotifiedAt DateTime?
  reportedBy    String                 // staff id
  createdAt     DateTime               @default(now())

  @@map("health_incidents")
}

// ═══════════════════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════════════════

model NotificationTemplate {
  id        String              @id @default(cuid())
  schoolId  String?
  school    School?             @relation(fields: [schoolId], references: [id])
  eventType String              // "student.absent", "fee.due", "result.published"
  channel   NotificationChannel
  language  String              @default("en")
  subject   String?
  body      String              @db.Text
  variables String[]            // list of template variables e.g. ["studentName", "className"]
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([schoolId, eventType, channel, language])
  @@map("notification_templates")
}

model Notification {
  id          String              @id @default(cuid())
  schoolId    String?
  recipientId String              // user id
  channel     NotificationChannel
  eventType   String
  title       String?
  body        String              @db.Text
  data        Json?               // extra payload
  status      NotificationStatus  @default(QUEUED)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failureReason String?
  retryCount  Int                 @default(0)
  createdAt   DateTime            @default(now())

  @@index([recipientId])
  @@index([status])
  @@map("notifications")
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  eventType String
  isEnabled Boolean             @default(true)
  updatedAt DateTime            @updatedAt

  @@unique([userId, channel, eventType])
  @@map("notification_preferences")
}

// ═══════════════════════════════════════════════════════════════════════════
// LMS
// ═══════════════════════════════════════════════════════════════════════════

model Course {
  id             String      @id @default(cuid())
  schoolId       String
  subjectId      String
  subject        Subject     @relation(fields: [subjectId], references: [id])
  gradeLevelId   String
  gradeLevel     GradeLevel  @relation(fields: [gradeLevelId], references: [id])
  academicYearId String?
  title          String
  description    String?
  thumbnailUrl   String?
  teacherStaffId String?     // primary teacher
  isPublished    Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  units      CourseUnit[]
  liveClasses LiveClass[]

  @@map("courses")
}

model CourseUnit {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  title       String
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  lessons Lesson[]

  @@map("course_units")
}

model Lesson {
  id             String     @id @default(cuid())
  unitId         String
  unit           CourseUnit @relation(fields: [unitId], references: [id])
  title          String
  description    String?
  type           String     @default("VIDEO")  // VIDEO, PDF, ARTICLE, AUDIO, LIVE_CLASS, AR_CONTENT
  contentUrl     String?
  articleHtml    String?    @db.Text
  durationSeconds Int       @default(0)
  recordingUrl   String?
  isFreePreview  Boolean    @default(false)
  isPublished    Boolean    @default(false)
  orderIndex     Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  lessonProgress LessonProgress[]
  lessonQuiz     LessonQuiz?
  discussions    LessonDiscussion[]
  liveClasses    LiveClass[]

  @@map("lessons")
}

model LessonProgress {
  id             String    @id @default(cuid())
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  lessonId       String
  lesson         Lesson    @relation(fields: [lessonId], references: [id])
  watchedSeconds Int       @default(0)
  scrollPercent  Float     @default(0)
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt @default(now())

  @@unique([studentId, lessonId])
  @@map("lesson_progress")
}

model LessonQuiz {
  id           String  @id @default(cuid())
  lessonId     String  @unique
  lesson       Lesson  @relation(fields: [lessonId], references: [id])
  onlineTestId String
  maxAttempts  Int     @default(3)
  passScore    Int     @default(60)
  createdAt    DateTime @default(now())

  @@map("lesson_quizzes")
}

model LessonDiscussion {
  id               String   @id @default(cuid())
  lessonId         String
  lesson           Lesson   @relation(fields: [lessonId], references: [id])
  authorId         String
  author           User     @relation(fields: [authorId], references: [id])
  content          String   @db.Text
  parentId         String?
  parent           LessonDiscussion?  @relation("DiscussionReplies", fields: [parentId], references: [id])
  replies          LessonDiscussion[] @relation("DiscussionReplies")
  moderationStatus String   @default("PENDING")  // PENDING, APPROVE, REMOVE
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("lesson_discussions")
}

model LiveClass {
  id              String   @id @default(cuid())
  lessonId        String
  lesson          Lesson   @relation(fields: [lessonId], references: [id])
  courseId        String?
  course          Course?  @relation(fields: [courseId], references: [id])
  sectionId       String?
  section         Section? @relation(fields: [sectionId], references: [id])
  hostStaffId     String
  title           String
  description     String?
  provider        String   @default("ZOOM")  // ZOOM, GOOGLE_MEET, BBB
  meetingLink     String
  roomId          String
  scheduledAt     DateTime
  durationMinutes Int      @default(60)
  status          String   @default("SCHEDULED")  // SCHEDULED, LIVE, ENDED, CANCELLED
  recordingUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendance LiveClassAttendance[]

  @@map("live_classes")
}

model LiveClassAttendance {
  id           String    @id @default(cuid())
  liveClassId  String
  liveClass    LiveClass @relation(fields: [liveClassId], references: [id])
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  joinedAt     DateTime
  markedPresent Boolean  @default(false)

  @@unique([liveClassId, studentId])
  @@map("live_class_attendance")
}

model SyllabicTopic {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  gradeLevelId String
  gradeLevel  GradeLevel @relation(fields: [gradeLevelId], references: [id])
  title       String
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  syllabusProgress SyllabusProgress[]

  @@map("syllabic_topics")
}

model SyllabusProgress {
  id               String        @id @default(cuid())
  syllabicTopicId  String
  syllabicTopic    SyllabicTopic @relation(fields: [syllabicTopicId], references: [id])
  staffId          String
  staff            Staff         @relation(fields: [staffId], references: [id])
  status           String        @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, REVISED
  completedDate    DateTime?
  remarks          String?
  updatedAt        DateTime      @updatedAt @default(now())

  @@unique([syllabicTopicId, staffId])
  @@map("syllabus_progress")
}

model Homework {
  id                    String   @id @default(cuid())
  schoolId              String
  teacherStaffId        String
  gradeLevelId          String
  gradeLevel            GradeLevel @relation(fields: [gradeLevelId], references: [id])
  sectionId             String?
  section               Section?   @relation("HomeworkSection", fields: [sectionId], references: [id])
  subjectId             String
  subject               Subject    @relation(fields: [subjectId], references: [id])
  description           String   @db.Text
  dueDate               DateTime
  assignedDate          DateTime @default(now())
  attachmentUrl         String?
  requiresAcknowledgement Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  acknowledgements HomeworkAcknowledgement[]

  @@index([schoolId, gradeLevelId])
  @@map("homework")
}

model HomeworkAcknowledgement {
  id             String   @id @default(cuid())
  homeworkId     String
  homework       Homework @relation(fields: [homeworkId], references: [id])
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  acknowledgedBy String
  acknowledgedAt DateTime @default(now())

  @@unique([homeworkId, studentId])
  @@map("homework_acknowledgements")
}

// ═══════════════════════════════════════════════════════════════════════════
// EVENTS, CERTIFICATES, SURVEYS, COMPLIANCE
// ═══════════════════════════════════════════════════════════════════════════

model Event {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  title       String
  description String?
  eventType   String   // SPORTS_DAY, ANNUAL_DAY, FIELD_TRIP, PTM, COMPETITION, CLUB
  startDate   DateTime
  endDate     DateTime?
  venue       String?
  maxParticipants Int?
  requiresConsent Boolean @default(false)
  budget      Decimal? @db.Decimal(12, 2)
  createdBy   String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model CertificateTemplate {
  id               String   @id @default(cuid())
  schoolId         String
  name             String
  certificateType  String
  htmlTemplate     String   @db.Text
  fieldMap         String[] // list of {{variable}} names
  logoUrl          String?
  signatureLabel   String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  requests IssuedCertificate[]

  @@map("certificate_templates")
}

model CertificateRequest {
  id                   String    @id @default(cuid())
  schoolId             String
  requestedBy          String
  studentId            String?
  student              Student?  @relation("CertificateRequests", fields: [studentId], references: [id])
  staffId              String?
  certificateType      String
  purpose              String?
  templateId           String?
  slaDeadline          DateTime
  status               String    @default("PENDING")  // PENDING, APPROVED, REJECTED, ISSUED
  reviewedBy           String?
  reviewedAt           DateTime?
  rejectionReason      String?
  issuedCertificateId  String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([schoolId, status])
  @@map("certificate_requests")
}

model IssuedCertificate {
  id              String          @id @default(cuid())
  schoolId        String
  studentId       String?
  student         Student?        @relation(fields: [studentId], references: [id])
  staffId         String?
  certificateType CertificateType
  certNo          String          @unique
  title           String?
  data            Json            // dynamic fields for the certificate
  pdfUrl          String?
  qrCode          String?
  templateId      String?
  template        CertificateTemplate? @relation(fields: [templateId], references: [id])
  blockchainHash  String?
  blockchainTxId  String?
  issuedBy        String
  issuedAt        DateTime        @default(now())
  revokedAt       DateTime?

  @@index([schoolId, certificateType])
  @@map("issued_certificates")
}

model Survey {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  title       String
  description String?
  targetRole  UserRole? // null = all
  isAnonymous Boolean  @default(false)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdBy   String
  createdAt   DateTime @default(now())

  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@map("surveys")
}

model SurveyQuestion {
  id           String   @id @default(cuid())
  surveyId     String
  survey       Survey   @relation(fields: [surveyId], references: [id])
  questionText String
  questionType String   @default("RATING") // RATING, MCQ, TEXT, CHECKBOX
  options      Json?
  isRequired   Boolean  @default(true)
  sequence     Int

  @@unique([surveyId, sequence])
  @@map("survey_questions")
}

model SurveyResponse {
  id         String   @id @default(cuid())
  surveyId   String
  survey     Survey   @relation(fields: [surveyId], references: [id])
  respondentId String? // null if anonymous
  answers    Json     // {questionId: answer}
  submittedAt DateTime @default(now())

  @@map("survey_responses")
}

// ═══════════════════════════════════════════════════════════════════════════
// PTM (PARENT-TEACHER MEETING)
// ═══════════════════════════════════════════════════════════════════════════

model PtmEvent {
  id                   String     @id @default(cuid())
  schoolId             String
  title                String
  eventDate            DateTime
  slotDurationMinutes  Int        @default(15)
  isVirtual            Boolean    @default(false)
  meetingPlatform      String?    // "Google Meet", "Zoom", etc.
  venue                String?
  status               String     @default("SCHEDULED") // SCHEDULED | ONGOING | COMPLETED | CANCELLED
  createdBy            String
  createdAt            DateTime   @default(now())

  slots                PtmSlot[]

  @@index([schoolId, eventDate])
  @@map("ptm_events")
}

model PtmSlot {
  id          String      @id @default(cuid())
  ptmEventId  String
  ptmEvent    PtmEvent    @relation(fields: [ptmEventId], references: [id])
  staffId     String
  staff       StaffMember @relation(fields: [staffId], references: [id])
  startTime   DateTime
  endTime     DateTime
  isBooked    Boolean     @default(false)
  createdAt   DateTime    @default(now())

  booking     PtmBooking?

  @@index([ptmEventId, staffId])
  @@map("ptm_slots")
}

model PtmBooking {
  id              String    @id @default(cuid())
  slotId          String    @unique
  slot            PtmSlot   @relation(fields: [slotId], references: [id])
  parentId        String
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id])
  notes           String?
  status          String    @default("CONFIRMED") // CONFIRMED | CANCELLED
  teacherRemarks  String?
  remarksAddedBy  String?
  remarksAddedAt  DateTime?
  createdAt       DateTime  @default(now())

  @@map("ptm_bookings")
}

model ComplianceCalendarItem {
  id              String   @id @default(cuid())
  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id])
  title           String
  complianceType  String   // "POSH_REPORT", "FIRE_DRILL", "EPF_RETURN", "UDISE", etc.
  frequency       String   // MONTHLY, QUARTERLY, ANNUAL
  dueDate         DateTime
  responsibleId   String?  // staff id
