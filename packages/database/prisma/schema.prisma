// ATTENDANCE
// ═══════════════════════════════════════════════════════════════════════════

model AttendanceSession {
  id           String   @id @default(cuid())
  schoolId     String
  sectionId    String
  section      Section  @relation(fields: [sectionId], references: [id])
  date         DateTime @db.Date
