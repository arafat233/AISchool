model NotificationTemplate {
  id        String              @id @default(cuid())
  schoolId  String?
  school    School?             @relation(fields: [schoolId], references: [id])
  eventType String              // "student.absent", "fee.due", "result.published"
  channel   NotificationChannel
  language  String              @default("en")
  subject   String?
  body      String              @db.Text
  variables String[]            // list of template variables e.g. ["studentName", "className"]
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([schoolId, eventType, channel, language])
  @@map("notification_templates")
}

model Notification {
  id          String              @id @default(cuid())
  schoolId    String?
  recipientId String              // user id
  channel     NotificationChannel
  eventType   String
  title       String?
  body        String              @db.Text
  data        Json?               // extra payload
  status      NotificationStatus  @default(QUEUED)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failureReason String?
  retryCount  Int                 @default(0)
  createdAt   DateTime            @default(now())

  @@index([recipientId])
  @@index([status])
  @@map("notifications")
}

model NotificationPreference {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  eventType String
  isEnabled Boolean             @default(true)
  updatedAt DateTime            @updatedAt

  @@unique([userId, channel, eventType])
  @@map("notification_preferences")
}

// ═══════════════════════════════════════════════════════════════════════════
// LMS
// ═══════════════════════════════════════════════════════════════════════════

model Course {
  id             String      @id @default(cuid())
  schoolId       String
  subjectId      String
  subject        Subject     @relation(fields: [subjectId], references: [id])
  gradeLevelId   String
  gradeLevel     GradeLevel  @relation(fields: [gradeLevelId], references: [id])
  academicYearId String?
  title          String
  description    String?
  thumbnailUrl   String?
  teacherStaffId String?     // primary teacher
  isPublished    Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  units      CourseUnit[]
  liveClasses LiveClass[]

  @@map("courses")
}

model CourseUnit {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  title       String
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  lessons Lesson[]

  @@map("course_units")
}

model Lesson {
  id             String     @id @default(cuid())
  unitId         String
  unit           CourseUnit @relation(fields: [unitId], references: [id])
  title          String
  description    String?
  type           String     @default("VIDEO")  // VIDEO, PDF, ARTICLE, AUDIO, LIVE_CLASS, AR_CONTENT
  contentUrl     String?
  articleHtml    String?    @db.Text
  durationSeconds Int       @default(0)
  recordingUrl   String?
  isFreePreview  Boolean    @default(false)
  isPublished    Boolean    @default(false)
  orderIndex     Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  lessonProgress LessonProgress[]
  lessonQuiz     LessonQuiz?
  discussions    LessonDiscussion[]
  liveClasses    LiveClass[]

  @@map("lessons")
}

model LessonProgress {
  id             String    @id @default(cuid())
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  lessonId       String
  lesson         Lesson    @relation(fields: [lessonId], references: [id])
  watchedSeconds Int       @default(0)
  scrollPercent  Float     @default(0)
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt @default(now())

  @@unique([studentId, lessonId])
  @@map("lesson_progress")
}

model LessonQuiz {
  id           String  @id @default(cuid())
  lessonId     String  @unique
  lesson       Lesson  @relation(fields: [lessonId], references: [id])
  onlineTestId String
  maxAttempts  Int     @default(3)
  passScore    Int     @default(60)
  createdAt    DateTime @default(now())

  @@map("lesson_quizzes")
}

model LessonDiscussion {
  id               String   @id @default(cuid())
  lessonId         String
  lesson           Lesson   @relation(fields: [lessonId], references: [id])
  authorId         String
  author           User     @relation(fields: [authorId], references: [id])
  content          String   @db.Text
  parentId         String?
  parent           LessonDiscussion?  @relation("DiscussionReplies", fields: [parentId], references: [id])
  replies          LessonDiscussion[] @relation("DiscussionReplies")
  moderationStatus String   @default("PENDING")  // PENDING, APPROVE, REMOVE
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("lesson_discussions")
}

model LiveClass {
  id              String   @id @default(cuid())
  lessonId        String
  lesson          Lesson   @relation(fields: [lessonId], references: [id])
  courseId        String?
  course          Course?  @relation(fields: [courseId], references: [id])
  sectionId       String?
  section         Section? @relation(fields: [sectionId], references: [id])
  hostStaffId     String
  title           String
  description     String?
  provider        String   @default("ZOOM")  // ZOOM, GOOGLE_MEET, BBB
  meetingLink     String
  roomId          String
  scheduledAt     DateTime
  durationMinutes Int      @default(60)
  status          String   @default("SCHEDULED")  // SCHEDULED, LIVE, ENDED, CANCELLED
  recordingUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attendance LiveClassAttendance[]

  @@map("live_classes")
}

model LiveClassAttendance {
  id           String    @id @default(cuid())
  liveClassId  String
  liveClass    LiveClass @relation(fields: [liveClassId], references: [id])
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])
  joinedAt     DateTime
  markedPresent Boolean  @default(false)

  @@unique([liveClassId, studentId])
  @@map("live_class_attendance")
}

model SyllabicTopic {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  gradeLevelId String
  gradeLevel  GradeLevel @relation(fields: [gradeLevelId], references: [id])
  title       String
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  syllabusProgress SyllabusProgress[]

  @@map("syllabic_topics")
}

model SyllabusProgress {
  id               String        @id @default(cuid())
  syllabicTopicId  String
  syllabicTopic    SyllabicTopic @relation(fields: [syllabicTopicId], references: [id])
  staffId          String
  staff            Staff         @relation(fields: [staffId], references: [id])
  status           String        @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, REVISED
  completedDate    DateTime?
  remarks          String?
  updatedAt        DateTime      @updatedAt @default(now())

  @@unique([syllabicTopicId, staffId])
  @@map("syllabus_progress")
}

model Homework {
  id                    String   @id @default(cuid())
  schoolId              String
  teacherStaffId        String
  gradeLevelId          String
  gradeLevel            GradeLevel @relation(fields: [gradeLevelId], references: [id])
  sectionId             String?
  section               Section?   @relation("HomeworkSection", fields: [sectionId], references: [id])
  subjectId             String
  subject               Subject    @relation(fields: [subjectId], references: [id])
  description           String   @db.Text
  dueDate               DateTime
  assignedDate          DateTime @default(now())
  attachmentUrl         String?
  requiresAcknowledgement Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  acknowledgements HomeworkAcknowledgement[]

  @@index([schoolId, gradeLevelId])
  @@map("homework")
}

model HomeworkAcknowledgement {
  id             String   @id @default(cuid())
  homeworkId     String
  homework       Homework @relation(fields: [homeworkId], references: [id])
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  acknowledgedBy String
  acknowledgedAt DateTime @default(now())

  @@unique([homeworkId, studentId])
  @@map("homework_acknowledgements")
}

