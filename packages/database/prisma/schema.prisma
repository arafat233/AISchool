  student     Student          @relation(fields: [studentId], references: [id])
  status      AttendanceStatus @default(PRESENT)
  remarks     String?
  editedBy    String?
  editedAt    DateTime?
  editReason  String?

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance_records")
}

model StaffAttendance {
  id          String           @id @default(cuid())
  staffId     String
  staff       Staff            @relation(fields: [staffId], references: [id])
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  source      String           @default("MANUAL") // MANUAL, BIOMETRIC
  remarks     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([staffId, date])
  @@map("staff_attendance")
}

// ═══════════════════════════════════════════════════════════════════════════
// FEE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

model FeeHead {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  name        String   // "Tuition", "Transport", "Library", "Sports"
  description String?
  isActive    Boolean  @default(true)
  isTaxable   Boolean  @default(false)
  hsnSacCode  String?
  taxRate     Decimal  @db.Decimal(5, 2) @default(0)
  createdAt   DateTime @default(now())

  feeStructures    FeeStructure[]
  feeInvoiceItems  FeeInvoiceItem[]
  concessions      Concession[]

  @@unique([schoolId, name])
  @@map("fee_heads")
}

model FeeStructure {
  id             String       @id @default(cuid())
  schoolId       String
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  termId         String?
  term           Term?        @relation(fields: [termId], references: [id])
  gradeLevelId   String
  gradeLevel     GradeLevel   @relation(fields: [gradeLevelId], references: [id])
  feeHeadId      String
  feeHead        FeeHead      @relation(fields: [feeHeadId], references: [id])
  amount         Decimal      @db.Decimal(12, 2)
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([academicYearId, termId, gradeLevelId, feeHeadId])
  @@map("fee_structures")
}

model FeeInvoice {
  id             String           @id @default(cuid())
  schoolId       String
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id])
  academicYearId String
  invoiceNo      String           @unique
  term           String?
  totalAmount    Decimal          @db.Decimal(12, 2)
  discountAmount Decimal          @db.Decimal(12, 2) @default(0)
  taxAmount      Decimal          @db.Decimal(12, 2) @default(0)
  netAmount      Decimal          @db.Decimal(12, 2)
  paidAmount     Decimal          @db.Decimal(12, 2) @default(0)
  dueDate        DateTime
  status         FeeInvoiceStatus @default(ISSUED)
  lateFeeApplied Decimal          @db.Decimal(10, 2) @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  items    FeeInvoiceItem[]
  payments FeePayment[]

  @@index([studentId])
  @@index([schoolId, status])
  @@map("fee_invoices")
}

model FeeInvoiceItem {
  id          String     @id @default(cuid())
  invoiceId   String
  invoice     FeeInvoice @relation(fields: [invoiceId], references: [id])
  feeHeadId   String
  feeHead     FeeHead    @relation(fields: [feeHeadId], references: [id])
  amount      Decimal    @db.Decimal(12, 2)
  concessionAmt Decimal  @db.Decimal(12, 2) @default(0)
  taxAmt      Decimal    @db.Decimal(12, 2) @default(0)
  netAmount   Decimal    @db.Decimal(12, 2)

  @@map("fee_invoice_items")
}

model FeePayment {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       FeeInvoice    @relation(fields: [invoiceId], references: [id])
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime      @default(now())
  mode          PaymentMode   @default(CASH)
  txnId         String?       // gateway transaction id
  gatewayOrderId String?
  gatewayPaymentId String?
  gatewaySignature String?
  chequeNo      String?
  bankName      String?
  receiptNo     String        @unique
  receiptUrl    String?
  status        PaymentStatus @default(SUCCESS)
  recordedBy    String?       // staff id for cash payments
  createdAt     DateTime      @default(now())

  @@index([invoiceId])
  @@map("fee_payments")
}

model Concession {
  id           String         @id @default(cuid())
  schoolId     String
  studentId    String
  feeHeadId    String
  feeHead      FeeHead        @relation(fields: [feeHeadId], references: [id])
  type         ConcessionType @default(PERCENTAGE)
  value        Decimal        @db.Decimal(10, 2) // % or flat amount
  reason       String
  academicYearId String?
  approvedBy   String?
  approvedAt   DateTime?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())

  @@map("concessions")
}

model LateFeeRule {
  id              String   @id @default(cuid())
  schoolId        String
  feeHeadId       String?  // null = applies to all heads
  triggerAfterDays Int     // days after due date
  type            ConcessionType @default(FLAT)
  amount          Decimal  @db.Decimal(10, 2)
  maxAmount       Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  @@map("late_fee_rules")
}

model PostDatedCheque {
  id           String        @id @default(cuid())
  schoolId     String
  studentId    String
  invoiceId    String?
  chequeNo     String
  bankName     String
  bankBranch   String?
  amount       Decimal       @db.Decimal(12, 2)
  chequeDate   DateTime
  depositedAt  DateTime?
  clearedAt    DateTime?
  bouncedAt    DateTime?
  bounceReason String?
  status       String        @default("PENDING") // PENDING, DEPOSITED, CLEARED, BOUNCED, RETURNED
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("post_dated_cheques")
}

// ═══════════════════════════════════════════════════════════════════════════
// EXAM & RESULTS
// ═══════════════════════════════════════════════════════════════════════════

model Exam {
  id             String     @id @default(cuid())
  schoolId       String
  school         School     @relation(fields: [schoolId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  termId         String?
  term           Term?      @relation(fields: [termId], references: [id])
  name           String
  type           ExamType   @default(UNIT_TEST)
  status         ExamStatus @default(DRAFT)
  internalsWeight Decimal   @db.Decimal(5, 2) @default(0)  // % weight for internals
  finalsWeight   Decimal    @db.Decimal(5, 2) @default(100)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  schedules   ExamSchedule[]
  hallTickets HallTicket[]
  results     Result[]

  @@index([schoolId, academicYearId])
  @@map("exams")
}

model ExamSchedule {
  id           String    @id @default(cuid())
  examId       String
  exam         Exam      @relation(fields: [examId], references: [id])
  subjectId    String
  subject      Subject   @relation(fields: [subjectId], references: [id])
  gradeLevelId String
  examDate     DateTime
  startTime    String?
  durationMins Int       @default(180)
  maxMarks     Decimal   @db.Decimal(6, 2)
  passMarks    Decimal   @db.Decimal(6, 2)
  venue        String?
  createdAt    DateTime  @default(now())

  marksEntries MarksEntry[]

  @@unique([examId, subjectId, gradeLevelId])
  @@map("exam_schedules")
}

model HallTicket {
  id              String   @id @default(cuid())
  examId          String
  exam            Exam     @relation(fields: [examId], references: [id])
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  ticketNo        String   @unique
  seatNo          String?
  venueAllocation String?
  pdfUrl          String?
  generatedAt     DateTime @default(now())

  @@unique([examId, studentId])
  @@map("hall_tickets")
}

model MarksEntry {
  id             String       @id @default(cuid())
  scheduleId     String
  schedule       ExamSchedule @relation(fields: [scheduleId], references: [id])
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id])
  marksObtained  Decimal      @db.Decimal(6, 2)
  grade          String?
  isAbsent       Boolean      @default(false)
  isGraceMark    Boolean      @default(false)
  graceMark      Decimal      @db.Decimal(4, 2) @default(0)
  enteredById    String       // staff id
  enteredAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([scheduleId, studentId])
  @@map("marks_entries")
}

model Result {
  id             String  @id @default(cuid())
  examId         String
  exam           Exam    @relation(fields: [examId], references: [id])
  studentId      String
  student        Student @relation(fields: [studentId], references: [id])
  totalMarks     Decimal @db.Decimal(8, 2)
  maxMarks       Decimal @db.Decimal(8, 2)
  percentage     Decimal @db.Decimal(5, 2)
  grade          String?
  classRank      Int?
  sectionRank    Int?
  isPassed       Boolean @default(true)
  subjectResults Json    // [{subjectId, subject, marks, maxMarks, grade}]
  reportCardUrl  String?
  calculatedAt   DateTime @default(now())
  publishedAt    DateTime?

  @@unique([examId, studentId])
  @@index([studentId])
  @@map("results")
}

model QuestionBank {
  id           String   @id @default(cuid())
  schoolId     String
  subjectId    String
  gradeLevelId String?
  questionType String   // MCQ, TRUE_FALSE, SHORT_ANSWER, FILL_BLANK, LONG_ANSWER
  questionText String   @db.Text
  options      Json?    // for MCQ: [{label, text, isCorrect}]
  correctAnswer String?
  marks        Decimal  @db.Decimal(4, 2) @default(1)
  difficulty   String   @default("MEDIUM") // EASY, MEDIUM, HARD
  topic        String?
  tags         String[]
  createdBy    String   // staff id
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([schoolId, subjectId, gradeLevelId])
  @@map("question_bank")
}

model OnlineTest {
  id               String   @id @default(cuid())
  schoolId         String
  title            String
  subjectId        String?
  gradeLevelId     String?
  durationMins     Int      @default(60)
  passingPercent   Decimal  @db.Decimal(5, 2) @default(40)
  shuffleQuestions Boolean  @default(false)
  showResultAfter  Boolean  @default(true)
  startAt          DateTime?
  endAt            DateTime?
  maxAttempts      Int      @default(1)
  isPublished      Boolean  @default(false)
  questionIds      String[] // ordered list of QuestionBank ids
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempts OnlineTestAttempt[]

  @@map("online_tests")
}

model OnlineTestAttempt {
  id          String     @id @default(cuid())
  testId      String
  test        OnlineTest @relation(fields: [testId], references: [id])
  studentId   String
  startedAt   DateTime   @default(now())
  submittedAt DateTime?
  score       Decimal?   @db.Decimal(6, 2)
  maxScore    Decimal?   @db.Decimal(6, 2)
  percentage  Decimal?   @db.Decimal(5, 2)
  answers     Json       @default("{}") // {questionId: selectedAnswer}
  timeTaken   Int?       // seconds
  isAutoSubmit Boolean   @default(false)

  @@unique([testId, studentId])
  @@map("online_test_attempts")
}

// ═══════════════════════════════════════════════════════════════════════════
// TRANSPORT
// ═══════════════════════════════════════════════════════════════════════════

model Route {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  name       String
  startPoint String?
  endPoint   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  stops    Stop[]
  vehicles Vehicle[]
  trips    Trip[]

  @@map("routes")
}

model Stop {
  id           String   @id @default(cuid())
  routeId      String
  route        Route    @relation(fields: [routeId], references: [id])
  name         String
  latitude     Float
  longitude    Float
  sequence     Int
  expectedTime String?  // "07:30"
  isActive     Boolean  @default(true)

  studentAssignments StudentTransport[]

  @@unique([routeId, sequence])
  @@map("stops")
}

model Vehicle {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])
  registrationNo String  @unique
  type          String   @default("BUS") // BUS, VAN, AUTO
  capacity      Int
  make          String?
  model         String?
  yearOfMfg     Int?
  gpsDeviceId   String?  // for MQTT tracking
  routeId       String?
  route         Route?   @relation(fields: [routeId], references: [id])
  currentDriverId String?
  insuranceExpiry DateTime?
  pucExpiry     DateTime?
  fitnessExpiry DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  driver  Driver?
  trips   Trip[]

  @@map("vehicles")
}

model Driver {
  id             String   @id @default(cuid())
  schoolId       String
  vehicleId      String?  @unique
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id])
  staffId        String?  // if driver is school staff
  name           String
  phone          String
  licenseNo      String   @unique
  licenseExpiry  DateTime
  licenseType    String   @default("LMV") // LMV, TRANSPORT
  bloodGroup     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("drivers")
}

model StudentTransport {
  id             String       @id @default(cuid())
  studentId      String       @unique
  student        Student      @relation(fields: [studentId], references: [id])
  routeId        String
  stopId         String
  stop           Stop         @relation(fields: [stopId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  pickupType     String       @default("BOTH") // PICKUP, DROP, BOTH
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@map("student_transport")
}

model Trip {
  id          String     @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle    @relation(fields: [vehicleId], references: [id])
  routeId     String
  route       Route      @relation(fields: [routeId], references: [id])
  driverId    String?
  tripDate    DateTime   @db.Date
  startedAt   DateTime?
  endedAt     DateTime?
  tripType    String     @default("MORNING") // MORNING, AFTERNOON, EVENING, TRIP
  status      TripStatus @default(SCHEDULED)
  notes       String?
  createdAt   DateTime   @default(now())

  @@map("trips")
}

