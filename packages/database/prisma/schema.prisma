model Enquiry {
  id               String    @id @default(cuid())
  schoolId         String
  studentName      String
  parentName       String
  parentPhone      String
  parentEmail      String?
  dateOfBirth      DateTime?
  applyingForGrade String?   // "Class 5", "KG", etc.
  source           String    @default("WALK_IN") // GOOGLE_ADS | REFERRAL | BANNER | WEBSITE | WALK_IN | SOCIAL | WHATSAPP
  referredBy       String?
  notes            String?
  status           String    @default("OPEN") // OPEN | FOLLOW_UP | CONVERTED | LOST
