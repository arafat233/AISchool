  remarks      String?
  createdAt    DateTime          @default(now())

  @@unique([schemeId, studentId, academicYearId])
  @@map("scholarship_applications")
}

// ═══════════════════════════════════════════════════════════════════════════
// PORTFOLIO & GAMIFICATION
// ═══════════════════════════════════════════════════════════════════════════

model PortfolioItem {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  title        String
  description  String?
  category     String   // "Academic", "Sports", "Arts", "Community Service"
  fileUrl      String?
  academicYear String?
  endorsedBy   String?  // staff id
  endorsement  String?
  createdAt    DateTime @default(now())

  @@map("portfolio_items")
}

model ReadingLog {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  bookId      String?  // from BookCatalogue if available
  title       String
  author      String?
  completedAt DateTime @default(now())
  review      String?
  rating      Int?     // 1-5
  validatedBy String?  // teacher staff id
  isValidated Boolean  @default(false)

  @@map("reading_logs")
}

// ═══════════════════════════════════════════════════════════════════════════
// VISITOR MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

model VisitorLog {
  id              String   @id @default(cuid())
  schoolId        String
  visitorName     String
  visitorPhone    String?
  visitorIdType   String?  // "Aadhar", "Passport", "DL"
  visitorIdNo     String?
  photoUrl        String?
  purpose         String
  hostName        String?
  hostDepartment  String?
  checkinAt       DateTime @default(now())
  checkoutAt      DateTime?
  passNo          String   @unique
  passType        String   @default("VISITOR") // VISITOR, DELIVERY, CONTRACTOR
  status          String   @default("ACTIVE")
  createdBy       String   // gate security staff id
  createdAt       DateTime @default(now())

  @@index([schoolId, checkinAt])
  @@map("visitor_logs")
}

model StudentGatePass {
  id          String   @id @default(cuid())
  schoolId    String
  studentId   String
  reason      String
  exitTime    DateTime?
  expectedReturnTime DateTime?
  actualReturnTime DateTime?
  parentApproved Boolean @default(false)
  parentApprovedAt DateTime?
  issuedBy    String
  createdAt   DateTime @default(now())

  @@map("student_gate_passes")
}
