  @@map("leave_balances")
}

model LeaveApplication {
  id                String   @id @default(cuid())
  staffId           String
  staff             Staff    @relation(fields: [staffId], references: [id])
  leaveType         String
  fromDate          DateTime
  toDate            DateTime
  days              Int
  reason            String
  documentUrl       String?
  academicYearId    String?
  substituteStaffId String?
  status            String   @default("PENDING") // PENDING, HOD_APPROVED, PRINCIPAL_APPROVED, APPROVED, REJECTED, CANCELLED
  reviewedBy        String?
  reviewedAt        DateTime?
  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

