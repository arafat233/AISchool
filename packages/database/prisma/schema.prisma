  assignedTo          String?
  resolutionDeadline  DateTime?
  resolution          String?
  resolvedAt          DateTime?
  escalatedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("staff_grievances")
}

model FreeSlot {
