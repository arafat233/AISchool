  spentAmt       Decimal  @db.Decimal(14, 2) @default(0)
  period         String   // "2024-25"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([schoolId, academicYearId, category])
  @@map("budget_allocations")
}

model ScholarshipScheme {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  name         String
  type         String   @default("MERIT") // MERIT, NEED_BASED, GOVERNMENT
  description  String?
  eligibilityCriteria Json @default("{}")
  discountType ConcessionType @default(PERCENTAGE)
